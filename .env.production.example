# PiyasaPilot production environment template.
# Bu dosyayı .env.production olarak kopyalayıp gerçek domain ve secret'larla doldurun.

APP_ENV=production
PUBLIC_BASE_URL=https://ornekdomain.com
CORS_ORIGINS=https://ornekdomain.com,https://www.ornekdomain.com
API_KEY=<guclu-rastgele-key>
STRICT_ENV_VALIDATION=1
LOG_LEVEL=WARNING

CLICKHOUSE_URL=http://clickhouse:8123/piyasapilot
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=<clickhouse-sifre>
CLICKHOUSE_DB=piyasapilot

DATABASE_URL=mysql+pymysql://piyasapilot:<mysql-sifre>@mysql:3306/piyasapilot
MYSQL_URL=mysql+aiomysql://piyasapilot:<mysql-sifre>@mysql:3306/piyasapilot
MYSQL_ROOT_PASSWORD=<mysql-root-sifre>
MYSQL_USER=piyasapilot
MYSQL_PASSWORD=<mysql-sifre>
MYSQL_DB=piyasapilot

REDIS_URL=redis://redis:6379/0

TELEGRAM_BOT_TOKEN=<telegram-token>
TELEGRAM_CHAT_ID=<telegram-chat-id>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<email>
SMTP_PASS=<app-password>
NOTIFY_EMAIL_TO=<email>

BIST_HTTP_URL_TEMPLATE=
BIST_HTTP_AUTH_HEADER=
VIOP_HTTP_URL_TEMPLATE=
VIOP_HTTP_AUTH_HEADER=
