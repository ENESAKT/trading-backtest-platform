# PiyasaPilot Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

# ─── Telegram Bot ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=

# ─── Notifier ─────────────────────────────────────────────────────────────
NOTIFY_API_URL=http://localhost:8000
NOTIFY_POLL_INTERVAL=30

# Telegram bildirim filtreleri
# symbol_group: bist30 | bist100 | crypto | custom
TELEGRAM_SIGNAL_TYPES=STRONG_BUY,STRONG_SELL
TELEGRAM_SYMBOLS=
TELEGRAM_MIN_STRENGTH=8
TELEGRAM_MIN_CONSENSUS_RATIO=0.6
TELEGRAM_COOLDOWN_MINUTES=30
TELEGRAM_QUIET_HOURS=

# ─── API ──────────────────────────────────────────────────────────────────
API_PORT=8000
LOG_LEVEL=INFO
# Dışa açılacaksa zorunlu; tanımlıysa tüm /api/* isteklerinde X-API-Key header gerekir
API_KEY=
# 1 yapılırsa eksik zorunlu .env değişkeni varsa servis başlamaz
STRICT_ENV_VALIDATION=0

# ─── Veritabanı Bağlantıları (Yeni Veri Platformu) ─────────────────────────
DATABASE_URL=mysql+pymysql://appuser:apppass@localhost:3306/metadata
CLICKHOUSE_URL=http://default:@localhost:8123/market_data
MYSQL_URL=mysql+aiomysql://appuser:apppass@localhost:3306/metadata
REDIS_URL=redis://localhost:6379/0

# ─── Lisanslı Veri Sağlayıcı Köprüleri (opsiyonel) ───────────────────────
# URL template placeholder'ları: {symbol}, {timeframe}/{interval}, {limit}
# Beklenen JSON: {"bars":[{"time":..., "open":..., "high":..., "low":..., "close":..., "volume":...}]}
BIST_HTTP_URL_TEMPLATE=
BIST_HTTP_AUTH_HEADER=
VIOP_HTTP_URL_TEMPLATE=
VIOP_HTTP_AUTH_HEADER=

# ─── ML / LightGBM (opsiyonel) ────────────────────────────────────────────
# `make retrain` çıktısını SignalGenerator ve backtest LightGBM stratejisine bağlar.
LIGHTGBM_MODEL_PATH=models/lightgbm/BTCUSDT_15m.txt
