# PiyasaPilot Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

# ─── Telegram Bot ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=

# ─── Notifier ─────────────────────────────────────────────────────────────
NOTIFY_API_URL=http://localhost:8000
NOTIFY_POLL_INTERVAL=30

# ─── API ──────────────────────────────────────────────────────────────────
API_PORT=8000
LOG_LEVEL=INFO
