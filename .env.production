APP_ENV=production
PUBLIC_BASE_URL=https://piyasapilot.com
CORS_ORIGINS=https://piyasapilot.com,https://www.piyasapilot.com
COOKIE_DOMAIN=piyasapilot.com
API_KEY_PROTECTED_PATHS=/metrics
REQUIRE_WS_API_KEY=0
API_KEY=BURAYA_YAZ
STRICT_ENV_VALIDATION=1
LOG_LEVEL=WARNING

# ─── JWT ──────────────────────────────────────────────────────────────────
# openssl rand -hex 32 ile üretin
JWT_SECRET=BURAYA_YAZ
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── MySQL (AWS RDS) ─────────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=piyasapilot
MYSQL_PASSWORD=BURAYA_YAZ
MYSQL_DATABASE=piyasapilot
MYSQL_DB=piyasapilot
MYSQL_ROOT_PASSWORD=BURAYA_YAZ
DATABASE_URL=mysql+pymysql://piyasapilot:BURAYA_YAZ@mysql:3306/piyasapilot
MYSQL_URL=mysql+aiomysql://piyasapilot:BURAYA_YAZ@mysql:3306/piyasapilot

# ─── ClickHouse ──────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://clickhouse:8123/piyasapilot
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=BURAYA_YAZ
CLICKHOUSE_DB=piyasapilot

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=BURAYA_YAZ
STRIPE_WEBHOOK_SECRET=BURAYA_YAZ
STRIPE_PRO_PRICE_ID=BURAYA_YAZ
STRIPE_ULTRA_PRICE_ID=BURAYA_YAZ
STRIPE_PRO_PRICE_ID_YEARLY=BURAYA_YAZ
STRIPE_ULTRA_PRICE_ID_YEARLY=BURAYA_YAZ

# ─── Google OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=BURAYA_YAZ
GOOGLE_CLIENT_SECRET=BURAYA_YAZ

# ─── Sentry ──────────────────────────────────────────────────────────────
SENTRY_DSN=BURAYA_YAZ

# ─── Telegram Bot ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=BURAYA_YAZ
TELEGRAM_CHAT_ID=BURAYA_YAZ

# ─── E-Posta (SMTP) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=BURAYA_YAZ
SMTP_PASS=BURAYA_YAZ
NOTIFY_EMAIL_TO=BURAYA_YAZ

# ─── Lisanslı Veri Sağlayıcılar (opsiyonel) ──────────────────────────────
# Bağlandığında aşağıdaki template'leri doldurun; boş bırakılırsa yfinance proxy aktif.
BIST_HTTP_URL_TEMPLATE=
BIST_HTTP_AUTH_HEADER=
VIOP_HTTP_URL_TEMPLATE=
VIOP_HTTP_AUTH_HEADER=

# ─── Diğer opsiyoneller ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LIGHTGBM_MODEL_PATH=models/lightgbm/BTCUSDT_15m.txt
